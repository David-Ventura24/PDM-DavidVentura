        }

        fun actualizarAlmacenamiento(NuevoAlmacenamiento : String){
            Almacenamiento = NuevoAlmacenamiento
        }

        val programasInstalados = listOf("Notion 2026", "Facebook 2024", "Chrome 2026", "Spotify 2025")


        fun programasActuales() {
            val filtrados = programasInstalados.filter { it.contains("2026") }
            println(filtrados)
        }




    }

class ProbarComputadora{
