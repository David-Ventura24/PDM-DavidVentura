import org.junit.Test

    class Computadora(var Procesador: String, var MemoriaRAM: Int, var Grafica: String, var SistemaOperativo: String, var Almacenamiento : String){

    fun Encender(){
        println("Encendiendo computadora")
    }

        fun Apagar(){
        println("Apagando computadora")
        }

        fun actualizarProcesador(nuevoProcesador : String){
            Procesador = nuevoProcesador
        }

        fun actualizarRAM(nuevaRAM : Int){
            MemoriaRAM = nuevaRAM
        }

        fun actualizarGrafica(nuevaGrafica : String){
            Grafica = nuevaGrafica
        }

        fun actualizarSO(nuevoSO : String){
